RewriteEngine On

RewriteRule ^(config\.php|config\.example\.php|lib\.php|schema\.sql|README\.md|INSTALL\.md|install\.sh|Dockerfile)$ - [F,L]

RewriteRule ^(lib|data|docs|docker|\.backups|\.git|\.github)(/|$) - [F,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^(.*)$ index.php [L,QSA]
